# Environment variables for OBH production server
# Copy this to /home/obh/omegabetaeta/.env and fill in real values.

FLASK_ENV=production
SECRET_KEY=CHANGE_ME_run_python3_-c_"import secrets; print(secrets.token_hex(32))"

# Google Calendar
SERVICE_ACCOUNT_FILE=/home/obh/omegabetaeta/service-account.json
PORTAL_CALENDAR_ID=your_portal_calendar_id_here
PUBLIC_CALENDAR_ID=your_public_calendar_id_here

# Email (for contact form replies)
EMAIL_ADDRESS=omegabetaeta@umich.edu
EMAIL_PASSWORD=your_app_password_here
SITE_URL=https://omegabetaeta.org

RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here