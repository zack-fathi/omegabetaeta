
#!/bin/bash
# PRODUCTION RUN SCRIPT
# Runs the Flask app using Gunicorn (production WSGI server).
# Usage: ./bin/obh_prod_run
#
# - Checks for the database file
# - Activates the virtual environment
# - Starts Gunicorn with 3 workers on port 8000

# Setting the path for the SQLite database
DB_PATH="var/obhapp.sqlite3"

# Check if the database file exists
if [ ! -f "$DB_PATH" ]; then
  echo "Error: can't find database $DB_PATH"
  echo "Try: ./bin/obhdb create"
  exit 1
fi

# Activate the virtual environment
source env/bin/activate

# stop previous instance if running
if pgrep -f "gunicorn.*obhapp:app" > /dev/null; then
    echo "Stopping existing Gunicorn instance..."
    pkill -f "gunicorn.*obhapp:app"
    sleep 2
fi

# Running the application with Gunicorn
echo "+ gunicorn -w 3 -b 0.0.0.0:8000 obhapp:app"
gunicorn -w 3 -b 0.0.0.0:8000 obhapp:app
